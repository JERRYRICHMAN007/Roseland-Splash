# Copy this file to server/.env and fill in values from Supabase:
# https://supabase.com/dashboard → your project → Project Settings → API
#
# This single file is used by:
#   • npm run dev:api  (Express API: signup, login, Paystack, …)
#   • npm run dev      (Vite reads it via vite.config.ts → browser Supabase client)
#
# Production (e.g. Vercel): set the same secrets in the host env; also set
# VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY for the frontend build if you
# do not rely on SUPABASE_* alone.
#
# Optional: one-time POST /api/admin/bootstrap-owner — set in server env only, never in Vite.
# MANAGER_BOOTSTRAP_SECRET=

PORT=3001
FRONTEND_URL=http://localhost:8080

# Optional: comma-separated extra browser origins allowed by CORS (e.g. Vercel preview URLs)
# ADDITIONAL_CORS_ORIGINS=https://your-app-git-branch.vercel.app

# Optional: comma-separated base URLs allowed as password-reset redirect origins (must match Supabase Redirect URLs)
# ADDITIONAL_REDIRECT_ORIGINS=https://your-production-domain.com,https://your-preview.vercel.app

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Use sk_test_… for local/testing; sk_live_… only in production.
PAYSTACK_SECRET_KEY=sk_test_PASTEHERE
